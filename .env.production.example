# в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# PRODUCTION environment вЂ” Vercel project `medcamp-prod` (branch: main)
#
# Prod gets its OWN dedicated Supabase project (`medcamp-prod`), using the default
# `public` schema вЂ” fully isolated from the shared non-prod project (separate
# credentials, compute, and blast radius). This is the 2nd of the two free DBs.
#
# Enter these in the Vercel project (Production scope of medcamp-prod) and in the
# GitHub Environment `production` (DATABASE_URL + DIRECT_URL; add a required
# reviewer there). TEMPLATE only вЂ” never commit real secrets. docs/Deployment.md.
#
# Posture: REAL tenant data, test-login OFF, Stripe LIVE mode (Connect).
# в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

# в”Ђв”Ђ App в”Ђв”Ђ
NEXT_PUBLIC_APP_URL=https://medcamp-prod.vercel.app
NEXT_PUBLIC_ROOT_DOMAIN=medcamp-prod.vercel.app
TENANT_ROUTING=path
DEFAULT_ORG_SLUG=dcica
BOOTSTRAP_ADMIN_EMAILS=lead@dcica.org,ops@dcica.org

# в”Ђв”Ђ Database (Supabase PROD project) в”Ђв”Ђ
DATABASE_URL=postgresql://postgres.<prod-ref>:<pw>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres.<prod-ref>:<pw>@<region>.pooler.supabase.com:5432/postgres
NEXT_PUBLIC_SUPABASE_URL=https://<prod-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<prod-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<prod-service-role-key>

# в”Ђв”Ђ Auth (NextAuth + Google OIDC) в”Ђв”Ђ
NEXTAUTH_SECRET=<unique-random-string>
NEXTAUTH_URL=https://medcamp-prod.vercel.app
GOOGLE_CLIENT_ID=<prod-google-client-id>
GOOGLE_CLIENT_SECRET=<prod-google-client-secret>

# в”Ђв”Ђ Payments (Stripe LIVE mode вЂ” Connect) в”Ђв”Ђ
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_SECRET_KEY=sk_live_xxx
# From the LIVE webhook endpoint at https://medcamp-prod.vercel.app/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_xxx

# в”Ђв”Ђ Address validation (optional; use a restricted key in prod) в”Ђв”Ђ
GOOGLE_MAPS_API_KEY=

# в”Ђв”Ђ Test-only login вЂ” MUST be OFF in production в”Ђв”Ђ
# Leave both UNSET. Do not set TEST_LOGIN_ENABLED=true on a real tenant вЂ” it is
# an auth back door. (Listed here only to document that it must stay off.)
# TEST_LOGIN_ENABLED=
# TEST_LOGIN_PASSWORD=

# в”Ђв”Ђ Email (real sender / verified domain) в”Ђв”Ђ
EMAIL_PROVIDER=resend
EMAIL_FROM="dcica <no-reply@dcica.org>"
RESEND_API_KEY=<prod-resend-key>
