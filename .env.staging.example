# ─────────────────────────────────────────────────────────────────────────────
# STAGING environment — Vercel project `medcamp-staging` (branch: staging)
#
# Shares the SINGLE non-prod Supabase project (`medcamp-nonprod`), isolated by
# Postgres schema `staging`. Only the `&schema=` differs from test/dev — same
# host, keys, and Supabase URL. No longer deferred: staging is live on the free
# tier via schema separation.
#
# Enter these in Vercel (Production scope of medcamp-staging) and in the GitHub
# Environment `staging` (DATABASE_URL + DIRECT_URL). TEMPLATE only — never commit
# real secrets. See docs/Deployment.md.
#
# Posture: mirrors prod config, test-login ON, Stripe TEST mode.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──
NEXT_PUBLIC_APP_URL=https://medcamp-staging.vercel.app
NEXT_PUBLIC_ROOT_DOMAIN=medcamp-staging.vercel.app
TENANT_ROUTING=path
DEFAULT_ORG_SLUG=dcica
BOOTSTRAP_ADMIN_EMAILS=team@example.com

# ── Database (Supabase NON-PROD project, schema=staging) ──
# Pre-create the schema once:  CREATE SCHEMA IF NOT EXISTS staging;
DATABASE_URL=postgresql://postgres.<nonprod-ref>:<pw>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&schema=staging
DIRECT_URL=postgresql://postgres.<nonprod-ref>:<pw>@<region>.pooler.supabase.com:5432/postgres?schema=staging
NEXT_PUBLIC_SUPABASE_URL=https://<nonprod-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<nonprod-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<nonprod-service-role-key>

# ── Auth (NextAuth + Google OIDC) ──
NEXTAUTH_SECRET=<unique-random-string>
NEXTAUTH_URL=https://medcamp-staging.vercel.app
GOOGLE_CLIENT_ID=<staging-google-client-id>
GOOGLE_CLIENT_SECRET=<staging-google-client-secret>

# ── Payments (Stripe TEST mode) ──
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
# From the webhook endpoint at https://medcamp-staging.vercel.app/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── Address validation (optional) ──
GOOGLE_MAPS_API_KEY=

# ── Test-only login (ON for staging) ──
TEST_LOGIN_ENABLED=true
TEST_LOGIN_PASSWORD=<shared-test-password>

# ── Email ──
EMAIL_PROVIDER=resend
EMAIL_FROM="dcica staging <no-reply@example.org>"
RESEND_API_KEY=
