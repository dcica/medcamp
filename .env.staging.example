# ─────────────────────────────────────────────────────────────────────────────
# STAGING environment — Vercel project `medcamp-staging` (branch: staging)
#
# DEFERRED: Supabase free tier allows only 2 active projects/org, so staging's
# database is not provisioned yet (test + prod use the two free slots). The
# Vercel project, this template, and the GitHub `staging` CI job are all ready —
# fill the DB values and add the GitHub `staging` secrets when a 3rd DB exists
# (paid upgrade or a freed slot). Until then the staging deploy runs but has no
# DB, and the staging migrate job self-skips. See docs/Deployment.md.
#
# Posture: mirrors prod config, test-login ON, Stripe TEST mode.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──
NEXT_PUBLIC_APP_URL=https://medcamp-staging.vercel.app
NEXT_PUBLIC_ROOT_DOMAIN=medcamp-staging.vercel.app
TENANT_ROUTING=path
DEFAULT_ORG_SLUG=dcica
BOOTSTRAP_ADMIN_EMAILS=team@example.com

# ── Database (Supabase STAGING project — DEFERRED, fill when provisioned) ──
DATABASE_URL=postgresql://postgres.<staging-ref>:<pw>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres.<staging-ref>:<pw>@<region>.pooler.supabase.com:5432/postgres
NEXT_PUBLIC_SUPABASE_URL=https://<staging-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<staging-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<staging-service-role-key>

# ── Auth (NextAuth + Google OIDC) ──
NEXTAUTH_SECRET=<unique-random-string>
NEXTAUTH_URL=https://medcamp-staging.vercel.app
GOOGLE_CLIENT_ID=<staging-google-client-id>
GOOGLE_CLIENT_SECRET=<staging-google-client-secret>

# ── Payments (Stripe TEST mode) ──
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
# From the webhook endpoint at https://medcamp-staging.vercel.app/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── Address validation (optional) ──
GOOGLE_MAPS_API_KEY=

# ── Test-only login (ON for staging) ──
TEST_LOGIN_ENABLED=true
TEST_LOGIN_PASSWORD=<shared-test-password>

# ── Email ──
EMAIL_PROVIDER=resend
EMAIL_FROM="dcica staging <no-reply@example.org>"
RESEND_API_KEY=
