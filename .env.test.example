# ─────────────────────────────────────────────────────────────────────────────
# TEST environment — Vercel project `medcamp-test` (branch: test)
#
# Shares the SINGLE non-prod Supabase project (`medcamp-nonprod`), isolated by
# Postgres schema `test`. Only the `&schema=` differs from staging/dev — the
# host, keys, and Supabase URL are the same across non-prod envs.
#
# Enter these in the Vercel project (Production scope of medcamp-test) and in the
# GitHub Environment `test` (DATABASE_URL + DIRECT_URL only). TEMPLATE — never put
# real secrets here; `.env*` is gitignored. See docs/Deployment.md.
#
# Posture: throwaway data, test-login ON, Stripe TEST mode.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──
NEXT_PUBLIC_APP_URL=https://medcamp-test.vercel.app
NEXT_PUBLIC_ROOT_DOMAIN=medcamp-test.vercel.app
TENANT_ROUTING=path
DEFAULT_ORG_SLUG=dcica
BOOTSTRAP_ADMIN_EMAILS=your-qa@example.com

# ── Database (Supabase NON-PROD project, schema=test) ──
# Prisma targets the `test` schema via &schema=test and qualifies all table names
# with it, so the shared transaction pooler is fine. Pre-create the schema once:
#   CREATE SCHEMA IF NOT EXISTS test;   (Supabase SQL editor)
# DATABASE_URL = Supavisor TRANSACTION pooler, port 6543, with the flags.
DATABASE_URL=postgresql://postgres.<nonprod-ref>:<pw>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&schema=test
# DIRECT_URL = direct/session connection, port 5432 (used by prisma migrate deploy).
DIRECT_URL=postgresql://postgres.<nonprod-ref>:<pw>@<region>.pooler.supabase.com:5432/postgres?schema=test
NEXT_PUBLIC_SUPABASE_URL=https://<nonprod-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<nonprod-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<nonprod-service-role-key>

# ── Auth (NextAuth + Google OIDC) ──
# Unique per env — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=<unique-random-string>
NEXTAUTH_URL=https://medcamp-test.vercel.app
GOOGLE_CLIENT_ID=<test-google-client-id>
GOOGLE_CLIENT_SECRET=<test-google-client-secret>

# ── Payments (Stripe TEST mode) ──
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
# From the Stripe webhook endpoint pointing at https://medcamp-test.vercel.app/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── Address validation (optional) ──
GOOGLE_MAPS_API_KEY=

# ── Test-only login (ON for test) ──
TEST_LOGIN_ENABLED=true
TEST_LOGIN_PASSWORD=<shared-test-password>

# ── Email (sandbox sender) ──
EMAIL_PROVIDER=resend
EMAIL_FROM="dcica test <no-reply@example.org>"
RESEND_API_KEY=
