# ─────────────────────────────────────────────────────────────────────────────
# dcica platform — environment configuration
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored —
# NEVER commit real secrets. Only this example file is tracked.
#
# Providers are pluggable (see docs/Platform-Mandate.md §6). Leave a section
# blank to disable that provider; the app falls back where a fallback exists.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
# Public base URL of this deployment (used for OAuth callbacks, email links, QR)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Minimum log level emitted by the structured logger (lib/logger). One of:
# debug | info | warn | error. Unset ⇒ debug in dev, info in production.
LOG_LEVEL=
# Multi-tenant routing strategy: "subdomain" (tenant.example.org) or "path" (/o/tenant)
TENANT_ROUTING=subdomain
# Apex/base domain for subdomain routing (omit for path routing in local dev)
NEXT_PUBLIC_ROOT_DOMAIN=localhost:3000
# Active tenant slug (Approach C single-tenant). Must match an Organization.slug.
DEFAULT_ORG_SLUG=dcica
# Comma-separated emails auto-granted COORDINATOR on first login (bootstrap the
# first admin, who then assigns other roles). e.g. "lead@org.example,ops@org.example"
BOOTSTRAP_ADMIN_EMAILS=

# ── Database (Supabase / Postgres) ───────────────────────────────────────────
# Pooled connection string used by the app at runtime
DATABASE_URL=postgresql://postgres:password@localhost:5432/dcica
# Direct (non-pooled) connection used for migrations
DIRECT_URL=postgresql://postgres:password@localhost:5432/dcica
# Supabase project (if using Supabase rather than self-managed Postgres)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only; bypasses RLS — guard carefully

# ── Auth (NextAuth.js — OIDC-first, tenant-scoped) ───────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-long-random-string
NEXTAUTH_URL=http://localhost:3000
# Configure at least one OIDC provider. Unset providers are simply not offered.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Payments (Stripe Connect — each tenant connects its OWN account) ──────────
# Platform keys: used ONLY to operate Connect onboarding, not to hold tenant funds.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx   # browser-safe
STRIPE_SECRET_KEY=sk_test_xxx                    # server-only, never exposed to client
STRIPE_WEBHOOK_SECRET=whsec_xxx                  # verify incoming Stripe webhooks
# Connect: clients of connected accounts are addressed via the Stripe-Account header,
# so no per-tenant key is stored here — tenant account IDs live in the database.
STRIPE_CONNECT_CLIENT_ID=ca_xxx

# ── Address validation (Google Address Validation API — optional) ────────────
# Standardizes mailing addresses (one call on field blur, NOT per-keystroke).
# Server-only key. Leave blank to disable — address fields fall back to plain
# text input. Free up to 5,000 validations/month, then usage-billed.
# https://developers.google.com/maps/documentation/address-validation
GOOGLE_MAPS_API_KEY=

# ── Test-only login (QA / demos / preview deploys) ───────────────────────────
# Enables a username/password screen at /test-login that bypasses OIDC and lets
# a tester assume any role. OFF unless explicitly "true". NEVER set true on a
# real production tenant — it is a deliberate auth back door for testing.
TEST_LOGIN_ENABLED=false
# Shared password for ALL test accounts (usernames: coordinator, regdesk,
# regdesk-notill, volunteer, doctor, pos, admin, volcoord). Dev fallback is
# "camp-test" if unset; set a real value before enabling anywhere shared.
TEST_LOGIN_PASSWORD=camp-test

# ── Email (pluggable: Resend | SendGrid | SMTP | SES) ────────────────────────
EMAIL_PROVIDER=resend            # one of: resend | sendgrid | smtp | ses
EMAIL_FROM="dcica <no-reply@example.org>"
RESEND_API_KEY=
SENDGRID_API_KEY=
# SMTP fallback (used when EMAIL_PROVIDER=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# AWS SES (used when EMAIL_PROVIDER=ses). EMAIL_FROM above must be a verified
# SES identity (domain or address) in this region, and the SES account must be
# out of the sandbox to email unverified recipients. Region is required;
# credentials resolve via the standard AWS chain below or an attached IAM role.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
